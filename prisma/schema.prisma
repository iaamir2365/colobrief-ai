generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id               String        @id @default(cuid())
  name             String
  email            String        @unique
  password         String
  doctorName       String?
  emailVerified    Boolean       @default(false)
  verificationToken String?
  symptomLogs      SymptomLog[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

model SymptomLog {
  id             String   @id @default(cuid())
  userId         String
  date           String
  painLevel      Float    @default(0)
  stoolFrequency Float    @default(0)
  stoolType      Float?
  stressLevel    Float    @default(0)
  triggers        String   @default("[]")
  notes           String?
  medicationTaken String?
  bloodInStool    Boolean  @default(false)
  urgencyLevel    Int      @default(0)
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([date])
}