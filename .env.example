# Environment Variables
# Copy this file to .env and fill in the values

# AI API Configuration (ZhiPu/GLM)
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# You can specify multiple API keys separated by commas for fallback
ZHIPU_API_KEY=your_zhipu_api_key_here
ZHIPU_API_KEYS=your_zhipu_api_key_here,your_second_zhipu_api_key_here,your_third_zhipu_api_key_here

# Mailtrap Configuration (Email Verification)
MAILTRAP_TOKEN=your_mailtrap_token_here
MAILTRAP_SENDER_EMAIL=your_sender_email_here
MAILTRAP_SENDER_NAME=ColoBrief AI

# JWT Secret Key (for authentication)
JWT_SECRET=your_secure_jwt_secret_key_here

# Turso Database Configuration
TURSO_DATABASE_URL="libsql://your-turso-database-url.turso.io"
TURSO_AUTH_TOKEN="your-turso-auth-token-here"
